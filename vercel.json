{
  "buildCommand": "node scripts/generate-sitemap.mjs && vite build && node scripts/generate-seo-pages.mjs",
  "outputDirectory": "dist",
  "redirects": [
    {
      "source": "/how-it-works",
      "destination": "/case-studies",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/((?!.*\\.[a-zA-Z0-9]{2,4}$).*)",
      "destination": "/index.html"
    }
  ]
}
